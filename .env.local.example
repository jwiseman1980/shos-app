# .env.local.example
# Copy this file to .env.local and fill in real values.
# Get secrets from Joseph (joseph.wiseman@steel-hearts.org) or the team lead.
# NEVER commit .env.local — it is in .gitignore.

# Supabase — Project A (HonorBase)
NEXT_PUBLIC_SUPABASE_URL=https://esoogmdwzcarvlodwbue.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=get_from_joseph
SUPABASE_SERVICE_ROLE_KEY=get_from_joseph

# Google Service Account (domain-wide delegation)
# Paste the full JSON contents of shos-signer.json as a single-line string.
GOOGLE_SERVICE_ACCOUNT_KEY=get_from_joseph

# Slack
SLACK_BOT_TOKEN=get_from_joseph
SLACK_SIGNING_SECRET=get_from_joseph

# Stripe
STRIPE_SECRET_KEY=get_from_joseph
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=get_from_joseph
STRIPE_WEBHOOK_SECRET=get_from_joseph

# ShipStation
SHIPSTATION_API_KEY=get_from_joseph
SHIPSTATION_API_SECRET=get_from_joseph

# Salesforce (backup mirror — read-only in most contexts)
SALESFORCE_USERNAME=get_from_joseph
SALESFORCE_PASSWORD=get_from_joseph
SALESFORCE_SECURITY_TOKEN=get_from_joseph
SALESFORCE_CLIENT_ID=get_from_joseph
SALESFORCE_CLIENT_SECRET=get_from_joseph

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
