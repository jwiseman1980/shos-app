# =============================================================================
# SHOS App Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file with real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Auth — App login and session management
# ---------------------------------------------------------------------------
LOGIN_PASSWORD=                          # Password for the app login page
SESSION_SECRET=                          # 256-bit hex secret for signing session cookies

# ---------------------------------------------------------------------------
# API Keys — External access (Claude, Slack bot, cron jobs)
# ---------------------------------------------------------------------------
SHOS_API_KEY=                            # API key for external callers (Claude, Cowork, Slack bot)
CRON_SECRET=                             # Secret for authenticating Vercel cron job requests

# ---------------------------------------------------------------------------
# Supabase — Primary database
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=                # Supabase project URL (https://<project>.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=           # Supabase publishable/anon key (safe for client)
SUPABASE_SERVICE_ROLE_KEY=               # Supabase service role key (server-side only, full access)
STORAGE_BACKEND=supabase                 # Storage backend: "supabase" or "salesforce"

# ---------------------------------------------------------------------------
# Google — Service account for Calendar and Gmail
# ---------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_EMAIL=            # Google service account email (*.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_KEY=              # Google service account private key (PEM format, newlines as \n)
GDRIVE_DESIGNS_FOLDER_ID=               # Google Drive folder ID for bracelet design files

# ---------------------------------------------------------------------------
# Salesforce — OAuth refresh-token flow (nightly backup mirror)
# ---------------------------------------------------------------------------
SF_LIVE=true                             # Enable Salesforce sync (true/false)
SF_CLIENT_ID=                            # Salesforce connected app client ID
SF_REFRESH_TOKEN=                        # Salesforce OAuth refresh token
SF_INSTANCE_URL=                         # Salesforce instance URL (https://<org>.my.salesforce.com)

# ---------------------------------------------------------------------------
# Slack — Webhooks and Bot
# ---------------------------------------------------------------------------
SLACK_SOP_WEBHOOK=                       # Incoming webhook URL for #ops-hub channel
SLACK_ANNIVERSARY_CHANNEL=               # Incoming webhook URL for anniversary notifications
SLACK_DM_CHRIS=                          # Incoming webhook URL for DM to Chris
SLACK_DM_JOSEPH=                         # Incoming webhook URL for DM to Joseph
SLACK_DM_KRISTIN=                        # Incoming webhook URL for DM to Kristin
SLACK_DM_RYAN=                           # Incoming webhook URL for DM to Ryan
SLACK_BOT_TOKEN=                         # Slack bot OAuth token (xoxb-...)
SLACK_SIGNING_SECRET=                    # Slack app signing secret for request verification

# ---------------------------------------------------------------------------
# Meta — Facebook + Instagram Graph API
# ---------------------------------------------------------------------------
META_APP_ID=                             # Meta/Facebook app ID
META_APP_SECRET=                         # Meta/Facebook app secret
META_PAGE_ACCESS_TOKEN=                  # Meta page access token (refresh every ~60 days)
META_PAGE_ID=                            # Facebook page ID
IG_USER_ID=                              # Instagram business account user ID

# ---------------------------------------------------------------------------
# ShipStation — Order fulfillment
# ---------------------------------------------------------------------------
SHIPSTATION_API_KEY=                     # ShipStation API key
SHIPSTATION_API_SECRET=                  # ShipStation API secret

# ---------------------------------------------------------------------------
# SendGrid — Transactional email
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=                        # SendGrid API key for sending emails

# ---------------------------------------------------------------------------
# Stripe — Donations and payments
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=                       # Stripe secret key (sk_live_... or sk_test_...)
STRIPE_WEBHOOK_SECRET=                   # Stripe webhook signing secret (whsec_...)

# ---------------------------------------------------------------------------
# Vercel — Hosting and deployment
# ---------------------------------------------------------------------------
# These are set automatically by Vercel at build time:
# VERCEL=1
# VERCEL_ENV=production|preview|development
# VERCEL_URL=<deployment-url>
# VERCEL_BRANCH_URL=<branch-url>
# VERCEL_PROJECT_PRODUCTION_URL=<production-url>

# ---------------------------------------------------------------------------
# Squarespace — Legacy order webhook
# ---------------------------------------------------------------------------
WEBHOOK_SECRET=                          # Shared secret for Squarespace order webhook (via Zapier)

# ---------------------------------------------------------------------------
# Anthropic — Claude AI
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=                       # Anthropic API key for Claude (sk-ant-...)

# ---------------------------------------------------------------------------
# Notion — Data migration (remove after Notion retirement)
# ---------------------------------------------------------------------------
NOTION_API_KEY=                          # Notion integration API key (ntn_...)

# ---------------------------------------------------------------------------
# Next.js Public — Client-side configuration
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=                   # App URL if different from VERCEL_URL
# NEXT_PUBLIC_BASE_URL=                  # Base URL for the app
# NEXT_PUBLIC_SITE_URL=                  # Public site URL
